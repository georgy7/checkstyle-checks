<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    This Checkstyle configuration is based on Sun Checks
    (https://github.com/checkstyle/checkstyle/blob/master/src/main/resources/sun_checks.xml)

    - The rule set has been updated: certain rules were removed while
      new ones were added, reflecting practical experience.
    - Checks are grouped according to the Checkstyle documentation
      (https://checkstyle.org/) to make the file easier to navigate.
    - Groups are separated by blank lines for better readability.
      When adding a new rule, please make sure it is placed in the appropriate group.
    - A few checks are disabled because their usage is situational.
      To enable or disable a check, simply comment or uncomment
      the corresponding <module> element.
-->
<module name="Checker">
    <property name="severity" value="error"/>
    <property name="charset" value="UTF-8"/>
    <property name="fileExtensions" value="java, properties, xml"/>

    <!-- 📁 Miscellaneous Checks -->
    <!-- See https://checkstyle.org/checks/misc/index.html -->
    <module name="NewlineAtEndOfFile"/>
    <!-- Can be enabled if checking keys in i18n *.properties files is required -->
    <!--
    <module name="Translation">
    </module>
    -->

    <!-- 📁 Size Violations Checks -->
    <!-- See https://checkstyle.org/checks/sizes/index.html -->
    <module name="FileLength"/>
    <module name="LineLength">
        <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
        <property name="max" value="180"/>
    </module>

    <!-- 📁 RegExp Checks -->
    <!-- https://checkstyle.sourceforge.io/checks/regexp/index.html -->
    <module name="RegexpSingleline">
        <property name="format" value="\s+$"/>
        <property name="minimum" value="0"/>
        <property name="maximum" value="0"/>
        <property name="message" value="Line has trailing spaces."/>
    </module>
    <module name="RegexpMultiline">
        <property name="format" value="/\*\*([^*]|\*(?!/))*?\*/\s*\r?\n\s*\r?\n"/>
        <property name="message" value="There must be no empty line after Javadoc comment."/>
        <property name="maximum" value="0"/>
        <property name="fileExtensions" value="java"/>
    </module>

    <!-- 📁 Whitespace Checks -->
    <!-- See https://checkstyle.org/checks/whitespace/index.html -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <!-- 📁 Filters -->
    <!-- See https://checkstyle.org/filters/index.html -->
    <!-- Filters warnings marked with @SuppressWarnings -->
    <module name="SuppressWarningsFilter"/>
    <module name="SuppressionFilter">
        <!-- Disables particular checks in test classes -->
        <property name="file" value="checkstyle-suppressions.xml"/>
    </module>

    <module name="TreeWalker">
        <property name="tabWidth" value="4"/>

        <!-- 📁 Annotations Checks -->
        <!-- See https://checkstyle.org/checks/annotation/index.html -->
        <!-- Processes @SuppressWarnings annotations in code -->
        <module name="SuppressWarningsHolder"/>

        <!-- 📁 Filters -->
        <!-- Processes // CHECKSTYLE:OFF and // CHECKSTYLE:ON comments in code -->
        <module name="SuppressionCommentFilter"/>

        <!-- 📁 Javadoc Checks -->
        <!-- See https://checkstyle.org/checks/javadoc/index.html -->
        <module name="JavadocMethod">
            <property name="allowMissingReturnTag" value="true"/>
        </module>
        <module name="JavadocType">
            <property name="excludeScope" value="package"/>
        </module>
        <!--
        <module name="JavadocVariable">
            <property name="excludeScope" value="private"/>
            <property name="accessModifiers" value="protected"/>
        </module>
        -->

        <!-- 📁 Naming Conventions Checks -->
        <!-- See https://checkstyle.org/checks/naming/index.html -->
        <module name="ConstantName"/>
        <module name="LocalFinalVariableName"/>
        <module name="LocalVariableName"/>
        <module name="MemberName"/>
        <module name="MethodName"/>
        <module name="PackageName"/>
        <module name="ParameterName"/>
        <module name="StaticVariableName"/>
        <module name="TypeName"/>

        <!-- 📁 Imports Checks -->
        <!-- See https://checkstyle.org/checks/imports/index.html -->
        <module name="AvoidStarImport">
            <!-- Allows star imports for large groups of static members, e.g., for JUnit assertions -->
            <property name="allowStaticMemberImports" value="true"/>
        </module>
        <module name="IllegalImport"/>
        <module name="RedundantImport"/>
        <module name="UnusedImports">
            <property name="processJavadoc" value="false"/>
        </module>

        <!-- 📁 Size Violations Checks -->
        <!-- See https://checkstyle.org/checks/sizes/index.html -->
        <module name="MethodLength">
            <!-- Default 150-180 can be insufficient for really tough methods. That's why countEmpty=false, too -->
            <property name="max" value="200"/>
            <property name="countEmpty" value="false"/>
        </module>
        <module name="ParameterNumber"/>

        <!-- 📁 Whitespace Checks -->
        <!-- See https://checkstyle.org/checks/whitespace/index.html -->
        <module name="EmptyForIteratorPad"/>
        <module name="EmptyLineSeparator">
            <property name="allowNoEmptyLineBetweenFields" value="true"/>
            <property name="allowMultipleEmptyLinesInsideClassMembers" value="false"/>
            <property name="allowMultipleEmptyLines" value="false"/>
        </module>
        <module name="GenericWhitespace"/>
        <module name="MethodParamPad"/>
        <module name="NoWhitespaceAfter"/>
        <module name="NoWhitespaceBefore"/>
        <module name="OperatorWrap"/>
        <module name="ParenPad"/>
        <module name="TypecastParenPad"/>
        <module name="WhitespaceAfter"/>
        <module name="WhitespaceAround"/>

        <!-- 📁 Modifiers Checks -->
        <!-- See https://checkstyle.org/checks/modifier/index.html -->
        <module name="ModifierOrder"/>
        <module name="RedundantModifier"/>

        <!-- 📁 Block Checks -->
        <!-- See https://checkstyle.org/checks/blocks/index.html -->
        <module name="AvoidNestedBlocks"/>
        <module name="EmptyBlock"/>
        <module name="LeftCurly"/>
        <module name="NeedBraces"/>
        <module name="RightCurly"/>

        <!-- 📁 Coding Checks -->
        <!-- See https://checkstyle.org/checks/coding/index.html -->
        <module name="DeclarationOrder"/>
        <module name="EmptyStatement"/>
        <module name="EqualsHashCode"/>
        <module name="HiddenField">
            <property name="ignoreSetter" value="true"/>
            <property name="ignoreConstructorParameter" value="true"/>
        </module>
        <module name="IllegalInstantiation"/>
        <module name="InnerAssignment"/>
        <!-- It is not about not using numbers in code. It is about giving numbers names (and meanings) -->
        <module name="MagicNumber"/>
        <module name="MissingSwitchDefault"/>
        <module name="SimplifyBooleanExpression"/>
        <module name="SimplifyBooleanReturn"/>

        <!-- 📁 Class Design Checks -->
        <!-- See https://checkstyle.org/checks/design/index.html -->
        <!--
        <module name="DesignForExtension">
            <property name="ignoredAnnotations" value="Override, Test"/>
        </module>
        -->
        <module name="FinalClass"/>
        <module name="HideUtilityClassConstructor">
            <property name="ignoreAnnotatedBy" value="UtilityClass, SpringBootApplication"/>
        </module>
        <module name="InterfaceIsType"/>
        <module name="VisibilityModifier">
            <!-- Allow protected fields in abstract classes for subclasses -->
            <property name="protectedAllowed" value="true"/>
        </module>

        <!-- 📁 Miscellaneous Checks -->
        <!-- See https://checkstyle.org/checks/misc/index.html -->
        <module name="ArrayTypeStyle"/>
        <!--
        <module name="TodoComment"/>
        -->
        <module name="UpperEll"/>
    </module>
</module>
